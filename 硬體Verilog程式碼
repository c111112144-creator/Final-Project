module vga_640x480(
    input  wire clk,
    input  wire rst,
    output wire [9:0] x,
    output wire [9:0] y,
    output wire       video_on,
    output wire       hsync,
    output wire       vsync,
    output wire       pixel_tick
);

    localparam H_DISPLAY = 640;
    localparam H_FRONT   = 16;
    localparam H_SYNC    = 96;
    localparam H_BACK    = 48;
    localparam H_TOTAL   = 800;

    localparam V_DISPLAY = 480;
    localparam V_FRONT   = 10;
    localparam V_SYNC    = 2;
    localparam V_BACK    = 33;
    localparam V_TOTAL   = 525;

    reg [1:0] pix_div;
    reg [9:0] h_count;
    reg [9:0] v_count;

    assign pixel_tick = (pix_div == 2'd0);

    always @(posedge clk or posedge rst) begin
        if (rst)
            pix_div <= 2'd0;
        else
            pix_div <= pix_div + 2'd1;
    end

    always @(posedge clk or posedge rst) begin
        if (rst) begin
            h_count <= 10'd0;
            v_count <= 10'd0;
        end else if (pixel_tick) begin
            if (h_count == H_TOTAL - 1) begin
                h_count <= 10'd0;

                if (v_count == V_TOTAL - 1)
                    v_count <= 10'd0;
                else
                    v_count <= v_count + 10'd1;
            end else begin
                h_count <= h_count + 10'd1;
            end
        end
    end

    assign x = h_count;
    assign y = v_count;

    assign video_on = (h_count < H_DISPLAY) && (v_count < V_DISPLAY);

    assign hsync = ~((h_count >= H_DISPLAY + H_FRONT) &&
                     (h_count <  H_DISPLAY + H_FRONT + H_SYNC));

    assign vsync = ~((v_count >= V_DISPLAY + V_FRONT) &&
                     (v_count <  V_DISPLAY + V_FRONT + V_SYNC));

endmodule


module uart_rx #(
    parameter CLK_FREQ = 100000000,
    parameter BAUD     = 4000000
)(
    input  wire      clk,
    input  wire      rst,
    input  wire      rx,
    output reg [7:0] data_out,
    output reg       data_valid
);

    localparam CLKS_PER_BIT = CLK_FREQ / BAUD;

    localparam U_IDLE  = 3'd0;
    localparam U_START = 3'd1;
    localparam U_DATA  = 3'd2;
    localparam U_STOP  = 3'd3;

    reg [2:0]  state;
    reg [15:0] clk_count;
    reg [2:0]  bit_index;
    reg [7:0]  rx_shift;

    reg rx_meta;
    reg rx_sync;

    always @(posedge clk or posedge rst) begin
        if (rst) begin
            rx_meta <= 1'b1;
            rx_sync <= 1'b1;
        end else begin
            rx_meta <= rx;
            rx_sync <= rx_meta;
        end
    end

    always @(posedge clk or posedge rst) begin
        if (rst) begin
            state      <= U_IDLE;
            clk_count  <= 16'd0;
            bit_index  <= 3'd0;
            rx_shift   <= 8'd0;
            data_out   <= 8'd0;
            data_valid <= 1'b0;
        end else begin
            data_valid <= 1'b0;

            case (state)

                U_IDLE: begin
                    clk_count <= 16'd0;
                    bit_index <= 3'd0;

                    if (rx_sync == 1'b0)
                        state <= U_START;
                end

                U_START: begin
                    if (clk_count == ((CLKS_PER_BIT - 1) / 2)) begin
                        if (rx_sync == 1'b0) begin
                            clk_count <= 16'd0;
                            state <= U_DATA;
                        end else begin
                            state <= U_IDLE;
                        end
                    end else begin
                        clk_count <= clk_count + 16'd1;
                    end
                end

                U_DATA: begin
                    if (clk_count < CLKS_PER_BIT - 1) begin
                        clk_count <= clk_count + 16'd1;
                    end else begin
                        clk_count <= 16'd0;
                        rx_shift[bit_index] <= rx_sync;

                        if (bit_index < 3'd7) begin
                            bit_index <= bit_index + 3'd1;
                        end else begin
                            bit_index <= 3'd0;
                            state <= U_STOP;
                        end
                    end
                end

                U_STOP: begin
                    if (clk_count < CLKS_PER_BIT - 1) begin
                        clk_count <= clk_count + 16'd1;
                    end else begin
                        clk_count <= 16'd0;

                        if (rx_sync == 1'b1) begin
                            data_out   <= rx_shift;
                            data_valid <= 1'b1;
                        end

                        state <= U_IDLE;
                    end
                end

                default: begin
                    state <= U_IDLE;
                end

            endcase
        end
    end

endmodule
